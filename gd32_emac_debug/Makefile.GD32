BOARD=BOARD_GD32F450VI

DEFINES+=DISPLAY_UDF

DEFINES+=ENABLE_HTTPD ENABLE_CONTENT

DEFINES+=CONFIG_STORE_USE_I2C
DEFINES+=CONFIG_USE_SOFTUART0

DEFINES+=DISABLE_RTC
DEFINES+=DISABLE_FS

DEFINES+=DEBUG_STACK
